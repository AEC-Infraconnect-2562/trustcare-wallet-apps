{
  "name": "trustcare-wallet-apps",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone TrustCare Wallet web and mobile applications.",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev:web": "pnpm --filter wallet-web dev",
    "dev:mobile": "pnpm --filter wallet-mobile start",
    "build:web": "pnpm --filter wallet-web build",
    "check": "pnpm -r check",
    "test": "pnpm -r test && pnpm test:gateway",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test --config=playwright.config.ts",
    "test:gateway": "node --test scripts/portal-hospital-issuer.test.mjs scripts/share-gateway-policy.test.mjs scripts/share-gateway-signing.test.mjs scripts/share-gateway-store.test.mjs scripts/share-gateway-verification.test.mjs",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "1.55.0",
    "@types/node": "^22.13.10",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
