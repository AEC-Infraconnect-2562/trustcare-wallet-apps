{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "VITE_TRUSTCARE_RUNTIME_ENV=demo pnpm build:web",
    "watchPatterns": [
      "apps/wallet-web/**",
      "packages/**",
      "scripts/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "node scripts/serve-wallet-web.mjs",
    "healthcheckPath": "/",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
